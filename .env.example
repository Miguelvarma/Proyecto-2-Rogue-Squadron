# ─── THE NEXUS BATTLES V — Chatbot Module ────────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env al repositorio.

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development              # production | development | test
PORT=8000                         # Puerto del servidor

# ─── IA (Groq) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxx   # API key de Groq. Obligatoria.

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL exacta del frontend. Sin wildcard en producción.
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=10                 # Máximo de mensajes permitidos en la ventana
RATE_LIMIT_WINDOW=60              # Ventana de tiempo en segundos

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info                    # info en producción, debug en desarrollo
