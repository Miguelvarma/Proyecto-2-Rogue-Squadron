NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nexus_battles
DB_USER=root
DB_PASSWORD=your_password
DB_POOL_LIMIT=10

# JWT
JWT_SECRET=your_jwt_secret_at_least_64_characters_long_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=your_refresh_secret_at_least_64_characters_long_xxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
HMAC_SECRET=your_hmac_secret_at_least_32_chars

# AI / Chatbot
AI_API_KEY=your_ai_api_key
AI_API_URL=https://api.groq.com/openai/v1

# Payments
PAYMENT_API_KEY=your_payment_api_key
PAYMENT_WEBHOOK_SECRET=your_webhook_secret
DEFAULT_PAYMENT_GATEWAY=mock

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Optional
APP_BASE_URL=http://localhost:3001
REDIS_URL=redis://localhost:6379
